# Coinbase Advanced Trade API credentials
# Get your CDP API key from https://portal.cdp.coinbase.com/access/api
COINBASE_API_KEY_NAME=organizations/xxx/apiKeys/yyy
COINBASE_API_SECRET="-----BEGIN EC PRIVATE KEY-----\nYOUR_PEM_KEY_HERE\n-----END EC PRIVATE KEY-----\n"

# Mode: "sandbox" or "production"
COINBASE_MODE=sandbox

# Set to "true" to use real Coinbase API instead of simulators
USE_REAL_COINBASE=false
